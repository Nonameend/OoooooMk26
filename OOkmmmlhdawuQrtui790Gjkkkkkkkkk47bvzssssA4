{Text = {vn = "Amibot Người Chơi", en = "Amibot Player"}, Script = [[

local Players = game:GetService("Players")

local RunService = game:GetService("RunService")

local UIS = game:GetService("UserInputService")

local workspace = game:GetService("Workspace")

local player = Players.LocalPlayer

if not player then return end

local playerGui = player:WaitForChild("PlayerGui")

if playerGui:FindFirstChild("Bom2devAmibotGui") then

    playerGui.Bom2devInvisGui:Destroy()

end

local gui = Instance.new("ScreenGui")

gui.Name = "Bom2devAmibotGui"

gui.ResetOnSpawn = false

gui.IgnoreGuiInset = true

gui.Parent = playerGui

local main = Instance.new("Frame", gui)

main.Size = UDim2.new(0,100,0,175)

main.Position = UDim2.new(0.06,0,0.42,0)

main.BackgroundColor3 = Color3.fromRGB(10,10,20)

main.BackgroundTransparency = 0.05

main.Active = true

main.Draggable = true

Instance.new("UICorner", main).CornerRadius = UDim.new(0,12)

local stroke = Instance.new("UIStroke", main)

stroke.Thickness = 2

task.spawn(function()

    local h = 0

    while task.wait(0.03) and gui.Parent do

        h = (h + 0.005) % 1

        stroke.Color = Color3.fromHSV(h, 0.95, 1)

    end

end)

local title = Instance.new("TextLabel", main)

title.Size = UDim2.new(1,-30,0,24)

title.Position = UDim2.new(0,21,0,8)

title.BackgroundTransparency = 1

title.Font = Enum.Font.GothamBold

title.TextSize = 16

title.Text = "Aimbot"

title.TextColor3 = Color3.fromRGB(220,255,250)

title.TextXAlignment = Enum.TextXAlignment.Left

local function NewBtn(parent, txt, posY)

    local b = Instance.new("TextButton", parent)

    b.Size = UDim2.fromOffset(90, 35)

    b.Position = UDim2.fromOffset(5, posY)

    b.BackgroundColor3 = Color3.fromRGB(60,200,170)

    b.Font = Enum.Font.GothamBold

    b.TextScaled = true

    b.TextColor3 = Color3.fromRGB(0,0,0)

    b.Text = txt

    Instance.new("UICorner", b).CornerRadius = UDim.new(0,8)

    local st = Instance.new("UIStroke", b)

    st.Thickness = 1

    st.Transparency = 0.6

    return b

end

local aimBtn = NewBtn(main, "Aimbot: Tắt", 44)

local teamBtn = NewBtn(main, "TeamCheck: Tắt", 44 + 46)

local modeBtn = NewBtn(main, "Mode: Bình thường", 44 + 92)

local AIMBOT = false

local AIM_RANGE = 500

local TEAM_CHECK = false

local AIM_MODE = "Bình thường"

local function isValidTarget(plr)

    if not plr or plr == player then return false end

    local char = plr.Character

    if not char then return false end

    local hum = char:FindFirstChildOfClass("Humanoid")

    if not hum or hum.Health <= 0 then return false end

    return true

end

local function choosePartByMode(char)

    if not char then return nil end

    if AIM_MODE == "Đầu" then

        return char:FindFirstChild("Head")

    else

        local hrp = char:FindFirstChild("HumanoidRootPart")

        if hrp then return hrp end

        local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("LowerTorso")

        if torso then return torso end

        return char:FindFirstChild("Head")

    end

end

local function makeRayParams()

    local rp = RaycastParams.new()

    rp.FilterType = Enum.RaycastFilterType.Blacklist

    rp.IgnoreWater = true

    return rp

end

local function isVisibleToCamera(targetPart)

    if not targetPart then return false end

    local cam = workspace.CurrentCamera

    if not cam then return false end

    local origin = cam.CFrame.Position

    local dir = targetPart.Position - origin

    if dir.Magnitude <= 0 then return false end

    local rp = makeRayParams()

    rp.FilterDescendantsInstances = {player.Character}

    local result = workspace:Raycast(origin, dir.Unit * math.min(dir.Magnitude, 1000), rp)

    if not result then

        return true

    end

    if result.Instance and result.Instance:IsDescendantOf(targetPart.Parent) then

        return true

    end

    return false

end

local function getNearestPlayer(maxRange)

    local nearest

    local nearestDist = math.huge

    local myChar = player.Character

    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart") or (myChar and (myChar:FindFirstChild("Torso") or myChar:FindFirstChild("UpperTorso") or myChar:FindFirstChild("LowerTorso")))

    if not myHrp then return nil end

    for _, plr in pairs(Players:GetPlayers()) do

        if isValidTarget(plr) then

            if TEAM_CHECK and player.Team and plr.Team and player.Team == plr.Team then

            else

                local part = choosePartByMode(plr.Character)

                if part and isVisibleToCamera(part) then

                    local dist = (part.Position - myHrp.Position).Magnitude

                    if dist < nearestDist and dist <= maxRange then

                        nearestDist = dist

                        nearest = plr

                    end

                end

            end

        end

    end

    return nearest, nearestDist

end

local function aimAtCharacterImmediate(plr)

    if not plr or not plr.Character then return end

    local cam = workspace.CurrentCamera

    if not cam then return end

    local part = choosePartByMode(plr.Character)

    if not part then return end

    local targetPos = part.Position

    local camPos = cam.CFrame.Position

    cam.CFrame = CFrame.new(camPos, targetPos)

    local myChar = player.Character

    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")

    if myHrp then

        local newLook = Vector3.new(targetPos.X, myHrp.Position.Y, targetPos.Z)

        myHrp.CFrame = CFrame.new(myHrp.Position, newLook)

    end

end

aimBtn.Activated:Connect(function()

    AIMBOT = not AIMBOT

    aimBtn.Text = AIMBOT and "Aimbot: Bật" or "Aimbot: Tắt"

    if AIMBOT then

        aimBtn.BackgroundColor3 = Color3.fromRGB(255,0,0)

    else

        aimBtn.BackgroundColor3 = Color3.fromRGB(60,200,170)

    end

end)

teamBtn.Activated:Connect(function()

    TEAM_CHECK = not TEAM_CHECK

    teamBtn.Text = TEAM_CHECK and "TeamCheck: Bật" or "TeamCheck: Tắt"

    if TEAM_CHECK then

        teamBtn.BackgroundColor3 = Color3.fromRGB(255,0,0)

    else

        teamBtn.BackgroundColor3 = Color3.fromRGB(60,200,170)

    end

end)

modeBtn.Activated:Connect(function()

    if AIM_MODE == "Bình thường" then

        AIM_MODE = "Đầu"

        modeBtn.Text = "Mode: Đầu"

        modeBtn.BackgroundColor3 = Color3.fromRGB(255,0,0)

        modeBtn.TextColor3 = Color3.fromRGB(0, 0, 0)

    else

        AIM_MODE = "Bình thường"

        modeBtn.Text = "Mode: Bình thường"

        modeBtn.BackgroundColor3 = Color3.fromRGB(60,200,170)

        modeBtn.TextColor3 = Color3.fromRGB(0,0,0)

    end

end)

RunService.RenderStepped:Connect(function()

    if not AIMBOT then return end

    local ok, target = pcall(function()

        return getNearestPlayer(AIM_RANGE)

    end)

    if ok and target then

        pcall(function()

            aimAtCharacterImmediate(target)

        end)

    end

end)

]]},

