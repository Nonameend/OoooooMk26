{Text = {vn = "Shift Lock", en = "Shift Lock"}, Script = [[

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

shared._ShiftLockXEnabled = shared._ShiftLockXEnabled or false
shared._ShiftLockXLoop = shared._ShiftLockXLoop or nil
shared._ShiftLockXCharConn = shared._ShiftLockXCharConn or nil

local function getCharacter()
	local char = player.Character
	if char and char.Parent then
		return char
	end
	return nil
end

local function getHumanoidAndRoot(char)
	if not char then
		return nil, nil
	end

	local humanoid = char:FindFirstChildOfClass("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")

	return humanoid, root
end

local function stopLoop()
	if shared._ShiftLockXLoop then
		shared._ShiftLockXLoop:Disconnect()
		shared._ShiftLockXLoop = nil
	end
end

local function applyShiftLock()
	local char = getCharacter()
	local humanoid, root = getHumanoidAndRoot(char)

	if not humanoid or not root then
		return
	end

	humanoid.AutoRotate = false
	UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

	stopLoop()

	shared._ShiftLockXLoop = RunService.RenderStepped:Connect(function()
		if not shared._ShiftLockXEnabled then
			return
		end

		if not char or not char.Parent then
			return
		end

		local cam = workspace.CurrentCamera
		if not cam then
			return
		end

		local look = cam.CFrame.LookVector
		local flat = Vector3.new(look.X, 0, look.Z)

		if flat.Magnitude > 0.001 then
			root.CFrame = CFrame.lookAt(root.Position, root.Position + flat.Unit, Vector3.yAxis)
		end
	end)
end

local function restoreNormal()
	stopLoop()

	UserInputService.MouseBehavior = Enum.MouseBehavior.Default

	local char = getCharacter()
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")

	if humanoid then
		humanoid.AutoRotate = true
	end
end

if not shared._ShiftLockXCharConn then
	shared._ShiftLockXCharConn = player.CharacterAdded:Connect(function()
		task.wait(0.15)

		if shared._ShiftLockXEnabled then
			applyShiftLock()
		end
	end)
end

shared._ShiftLockXEnabled = not shared._ShiftLockXEnabled

if shared._ShiftLockXEnabled then
	applyShiftLock()
else
	restoreNormal()
end

]]},
{Text = {vn = "Ảo ảnh", en = "Illusion"}, Script = [[

local Players = game.Players
local RunService = game.RunService

local G = (getgenv and getgenv()) or _G
G.Bom2devIllusionState = G.Bom2devIllusionState or { active = false }

if G.Bom2devIllusionState.active then
	G.Bom2devIllusionState.active = false
	if G.Bom2devIllusionState.cleanup then
		pcall(G.Bom2devIllusionState.cleanup)
	end
	return
end

G.Bom2devIllusionState.active = true

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local size = Vector3.new(200, 200, 200)
local moveTime = 0.0001

local enabled = true
local center
local planeY

local char, root, hum
local att, alignPos, alignOri
local centerPart

local hbConn
local loopConn
local deathConn

local oldCamType
local oldCamSubject
local oldCamMinZoom
local oldCamMaxZoom

local oldCollide = {}
local cleaning = false

local function getChar()
	return player.Character or player.CharacterAdded:Wait()
end

local function getRoot(c)
	return c:WaitForChild("HumanoidRootPart")
end

local function getHum(c)
	return c:FindFirstChildOfClass("Humanoid")
end

local function setCollide(character, state)
	for _, v in ipairs(character:GetDescendants()) do
		if v:IsA("BasePart") then
			if state == false then
				oldCollide[v] = v.CanCollide
				v.CanCollide = false
			else
				if oldCollide[v] ~= nil then
					v.CanCollide = oldCollide[v]
				else
					v.CanCollide = true
				end
			end
		end
	end
end

local function makeCenterPart(pos)
	local p = Instance.new("Part")
	p.Name = "Bom2devCenterPart"
	p.Size = Vector3.new(1, 1, 1)
	p.Anchored = true
	p.CanCollide = false
	p.CanTouch = false
	p.CanQuery = false
	p.Transparency = 1
	p.CastShadow = false
	p.CFrame = CFrame.new(pos)
	p.Parent = workspace
	return p
end

local function randEdge(c)
	local hx, hz = size.X / 2, size.Z / 2
	local r = math.random(1, 6)

	if r == 1 then
		return c + Vector3.new(math.random(-hx, hx), math.random(-size.Y / 2, size.Y / 2), -hz)
	elseif r == 2 then
		return c + Vector3.new(math.random(-hx, hx), math.random(-size.Y / 2, size.Y / 2), hz)
	elseif r == 3 then
		return c + Vector3.new(-hx, math.random(-size.Y / 2, size.Y / 2), math.random(-hz, hz))
	elseif r == 4 then
		return c + Vector3.new(hx, math.random(-size.Y / 2, size.Y / 2), math.random(-hz, hz))
	elseif r == 5 then
		return c + Vector3.new(math.random(-hx, hx), size.Y / 2, math.random(-hz, hz))
	else
		return c + Vector3.new(math.random(-hx, hx), -size.Y / 2, math.random(-hz, hz))
	end
end

local function clamp(v)
	return Vector3.new(v.X, planeY, v.Z)
end

local function outOfBounds(p)
	local d = p - center
	return math.abs(d.X) > size.X / 2 or math.abs(d.Z) > size.Z / 2
end

local function stopCamera()
	camera.CameraType = oldCamType or Enum.CameraType.Custom
	camera.CameraSubject = oldCamSubject or hum
	if oldCamMinZoom then
		player.CameraMinZoomDistance = oldCamMinZoom
	end
	if oldCamMaxZoom then
		player.CameraMaxZoomDistance = oldCamMaxZoom
	end
end

local function cleanup()
	if cleaning then
		return
	end
	cleaning = true
	enabled = false

	if hbConn then hbConn:Disconnect() end
	if loopConn then task.cancel(loopConn) end
	if deathConn then deathConn:Disconnect() end

	task.spawn(function()
		if root and root.Parent then
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
			root.Anchored = true
			task.wait(1.5)
			if root and root.Parent then
				root.AssemblyLinearVelocity = Vector3.zero
				root.AssemblyAngularVelocity = Vector3.zero
				root.Anchored = false
			end
		end

		if alignPos then alignPos:Destroy() end
		if alignOri then alignOri:Destroy() end
		if att then att:Destroy() end

		if centerPart then
			centerPart:Destroy()
			centerPart = nil
		end

		stopCamera()

		if char then
			setCollide(char, true)
		end

		if root and root.Parent then
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
		end

		G.Bom2devIllusionState.active = false
		G.Bom2devIllusionState.cleanup = nil
	end)
end

G.Bom2devIllusionState.cleanup = cleanup

local function start()
	char = getChar()
	root = getRoot(char)
	hum = getHum(char)

	center = root.Position
	planeY = root.Position.Y

	oldCamType = camera.CameraType
	oldCamSubject = camera.CameraSubject
	oldCamMinZoom = player.CameraMinZoomDistance
	oldCamMaxZoom = player.CameraMaxZoomDistance

	player.CameraMinZoomDistance = 8
	player.CameraMaxZoomDistance = 120

	setCollide(char, false)

	centerPart = makeCenterPart(center)
	camera.CameraType = Enum.CameraType.Custom
	camera.CameraSubject = centerPart

	deathConn = hum.Died:Connect(function()
