local rumble, zap

local electricTrails = {}

local heartbeatConn

local activeTween

local camTween

local deathConn

local function cleanupTrails()

	for _, v in ipairs(electricTrails) do

		pcall(function() if v then v:Destroy() end end)

	end

	electricTrails = {}

end

local function cleanupSounds()

	if rumble then pcall(function() rumble:Destroy() end) rumble = nil end

	if zap then pcall(function() zap:Destroy() end) zap = nil end

end

local function safeFind(r6, r15)

	if not char then return nil end

	return char:FindFirstChild(r6) or char:FindFirstChild(r15)

end

local function createSounds()

	if not hrp then return end

	cleanupSounds()

	rumble = Instance.new("Sound")

	rumble.SoundId = "rbxassetid://1837635124"

	rumble.Looped = true

	rumble.Volume = 1

	rumble.Parent = hrp

	zap = Instance.new("Sound")

	zap.SoundId = "rbxassetid://138218317"

	zap.Volume = 1

	zap.Parent = hrp

end

local function lightningTrail()

	if not hrp then return end

	local a0 = Instance.new("Attachment", hrp)

	local a1 = Instance.new("Attachment", hrp)

	a0.Position = Vector3.new(0, 1, 0)

	a1.Position = Vector3.new(0, -1, 0)

	local trail = Instance.new("Trail", hrp)

	trail.Attachment0 = a0

	trail.Attachment1 = a1

	trail.Color = ColorSequence.new{

		ColorSequenceKeypoint.new(0, Color3.fromRGB(255,80,45)),

		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,220,40)),

		ColorSequenceKeypoint.new(1, Color3.fromRGB(255,80,30))

	}

	trail.Lifetime = 0.55

	trail.WidthScale = NumberSequence.new{

		NumberSequenceKeypoint.new(0, 1),

		NumberSequenceKeypoint.new(1, 0)

	}

	trail.Transparency = NumberSequence.new(0.35)

	trail.LightEmission = 0.7

	Debris:AddItem(trail, 0.9)

	Debris:AddItem(a0, 0.9)

	Debris:AddItem(a1, 0.9)

	table.insert(electricTrails, trail)

	table.insert(electricTrails, a0)

	table.insert(electricTrails, a1)

end

local function createElectricTrails()

	cleanupTrails()

	if not char or not hrp then return end

	local parts = {

		{part = safeFind("Head","Head"), offset = Vector3.new(0, 0.4, 0)},

		{part = safeFind("Left Arm","LeftUpperArm"), offset = Vector3.new(0, -0.5, 0)},

		{part = safeFind("Right Arm","RightUpperArm"), offset = Vector3.new(0, -0.5, 0)},

		{part = safeFind("Left Leg","LeftUpperLeg"), offset = Vector3.new(0, -0.5, 0)},

		{part = safeFind("Right Leg","RightUpperLeg"), offset = Vector3.new(0, -0.5, 0)},

		{part = hrp, offset = Vector3.new(0.5, 1, 0)}

	}

	for _, info in ipairs(parts) do

		if info.part and info.part.Parent then

			local att0 = Instance.new("Attachment", info.part)

			local att1 = Instance.new("Attachment", info.part)

			att0.Position = info.offset

			att1.Position = info.offset + Vector3.new(0, -0.3, 0)

			local trail = Instance.new("Trail", info.part)

			trail.Attachment0 = att0

			trail.Attachment1 = att1

			trail.Color = ColorSequence.new{

				ColorSequenceKeypoint.new(0, Color3.fromRGB(255,80,30)),

				ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,220,40)),

				ColorSequenceKeypoint.new(1, Color3.fromRGB(255,80,30))

			}

			trail.Lifetime = 0.52

			trail.Transparency = NumberSequence.new(0.2)

			trail.WidthScale = NumberSequence.new(0.5)

			trail.LightEmission = 10

			table.insert(electricTrails, trail)

			table.insert(electricTrails, att0)

			table.insert(electricTrails, att1)

		end

	end

end

local function cancelTweens()

	if activeTween then pcall(function() activeTween:Cancel() end) activeTween = nil end

	if camTween then pcall(function() camTween:Cancel() end) camTween = nil end

end

local function tweenSpeed(target, time)

	if not humanoid then return end

	cancelTweens()

	activeTween = TweenService:Create(

		humanoid,

		TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),

		{WalkSpeed = target}

	)

	activeTween:Play()

end

local function stopFlash()

	isFlash = false

	cancelTweens()

	if heartbeatConn then heartbeatConn:Disconnect() heartbeatConn = nil end

	if humanoid then humanoid.WalkSpeed = normalSpeed end

	if rumble then rumble:Stop() end

	if cam then cam.FieldOfView = 70 end

	cleanupTrails()

end

local function startFlash(speed)

	if not humanoid or not hrp then return end

	isFlash = true

	currentSpeed = speed

	createSounds()

	createElectricTrails()

	if rumble then rumble:Play() end

	camTween = TweenService:Create(cam, TweenInfo.new(0.25), {FieldOfView = 110})

	camTween:Play()

	tweenSpeed(speed, 1)

	if heartbeatConn then heartbeatConn:Disconnect() end

	heartbeatConn = RunService.Heartbeat:Connect(function()

		if not isFlash or not humanoid then return end

		if humanoid.MoveDirection.Magnitude > 0.1 then

			if math.random() < 0.2 and zap and not zap.IsPlaying then

				zap:Play()

			end

			lightningTrail()

		end

	end)

end

local function toggleFlash()

	if not humanoid or not hrp then return end

	if isFlash then

		stopFlash()

	else

		local val = tonumber(box.Text)

		if not val or val <= 0 then val = 50 box.Text = "50" end

		startFlash(val)

	end

end

local function onCharacterAdded(c)

	char = c

	humanoid = c:WaitForChild("Humanoid")

	hrp = c:WaitForChild("HumanoidRootPart")

	createSounds()

	if deathConn then deathConn:Disconnect() end

	deathConn = humanoid.Died:Connect(function()

		stopFlash()

		cleanupSounds()

	end)

end

if player.Character then onCharacterAdded(player.Character) end

player.CharacterAdded:Connect(onCharacterAdded)

local PlayerGui = player:WaitForChild("PlayerGui")

if PlayerGui:FindFirstChild("TheFlashGui") then

	PlayerGui.TheFlashGui:Destroy()

end

local gui = Instance.new("ScreenGui")

gui.Name = "TheFlashGui"

gui.ResetOnSpawn = false

gui.Parent = PlayerGui

local main = Instance.new("Frame", gui)

main.Size = UDim2.new(0,180,0,70)

main.Position = UDim2.new(0.05,0,0.75,0)

main.BackgroundColor3 = Color3.fromRGB(12,12,20)

main.BackgroundTransparency = 0.03

main.Active = true

main.Draggable = true

Instance.new("UICorner", main).CornerRadius = UDim.new(0,12)

local stroke = Instance.new("UIStroke", main)

stroke.Thickness = 2

stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

task.spawn(function()

	local h = 0

	while gui.Parent do

		h = (h + 0.01) % 1

		stroke.Color = Color3.fromHSV(h,0.85,1)

		task.wait(0.05)

	end

end)

local title = Instance.new("TextLabel", main)

title.Size = UDim2.new(1,0,0,20)

title.Position = UDim2.new(0,0,0,3)

title.BackgroundTransparency = 1

title.Font = Enum.Font.GothamBold

title.TextSize = 14

title.Text = "The Flash"

title.TextColor3 = Color3.fromRGB(220,230,255)

box = Instance.new("TextBox", main)

box.Size = UDim2.new(0.6,0,0,26)

box.Position = UDim2.new(0.05,0,0.5,0)

box.BackgroundColor3 = Color3.fromRGB(25,25,35)

box.PlaceholderText = "Speed (vd 50)"

box.ClearTextOnFocus = false

box.Font = Enum.Font.Gotham

box.TextScaled = true

box.TextColor3 = Color3.fromRGB(255,255,255)

box.Text = "50"

Instance.new("UICorner", box).CornerRadius = UDim.new(0,8)

local uiBtn = Instance.new("TextButton", main)

uiBtn.Size = UDim2.new(0.25,0,0,26)

uiBtn.Position = UDim2.new(0.7,0,0.5,0)

uiBtn.BackgroundColor3 = Color3.fromRGB(60,200,120)

uiBtn.Font = Enum.Font.GothamBold

uiBtn.TextSize = 16

uiBtn.Text = "BẬT"

uiBtn.TextColor3 = Color3.fromRGB(0,0,0)

Instance.new("UICorner", uiBtn).CornerRadius = UDim.new(0,8)

local function updateBtn()

	if isFlash then

		uiBtn.Text = "TẮT"

		uiBtn.BackgroundColor3 = Color3.fromRGB(230,80,60)

	else

		uiBtn.Text = "BẬT"

		uiBtn.BackgroundColor3 = Color3.fromRGB(60,200,120)

	end

end

uiBtn.MouseButton1Click:Connect(function()

	toggleFlash()

	updateBtn()

end)

updateBtn()

]]},
{Text = {vn = "Avade", en = "Avade"}, Script = [[

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local SaveFileName = "AVADESettings.json"
local DEFAULT_SPEED = 16
local DEFAULT_JUMP = 50
local DEFAULT_FOV = 70
local IDLE_FOV = 70
local MOVE_FOV = 100
local ENABLE_GRAVITY = 8

local function saveData(data)
	pcall(function()
		if writefile then
			writefile(SaveFileName, HttpService:JSONEncode(data))
		end
	end)
end

local function loadData()
	local data = { SpeedValue = 50, JumpValue = 75 }
	pcall(function()
		if readfile and isfile and isfile(SaveFileName) then
			data = HttpService:JSONDecode(readfile(SaveFileName))
		end
	end)
	return data
end

local savedData = loadData()
local lastSpeed = tonumber(savedData.SpeedValue) or 50
local lastJump = tonumber(savedData.JumpValue) or 75

if playerGui:FindFirstChild("AVADEGui") then
	pcall(function()
		playerGui.AVADEGui:Destroy()
	end)
end

local gui = Instance.new("ScreenGui")
gui.Name = "AVADEGui"
gui.IgnoreGuiInset = true
gui.ResetOnSpawn = false
gui.Parent = playerGui

local main = Instance.new("Frame")
main.Size = UDim2.new(0, 170, 0, 70)
main.Position = UDim2.new(0.05, 0, 0.8, 0)
main.BackgroundColor3 = Color3.fromRGB(10, 10, 20)
main.BackgroundTransparency = 0.1
main.Active = true
main.Draggable = true
main.Parent = gui

Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)

local stroke = Instance.new("UIStroke", main)
stroke.Thickness = 2
stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

task.spawn(function()
	local hue = 0
	while gui.Parent do
		hue = (hue + 0.01) % 1
		stroke.Color = Color3.fromHSV(hue, 1, 1)
		task.wait(0.05)
	end
end)

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 20)
title.BackgroundTransparency = 1
title.Text = "AVADE"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 16

local speedBox = Instance.new("TextBox", main)
speedBox.Size = UDim2.new(0.55, 0, 0, 25)
speedBox.Position = UDim2.new(0.05, 0, 0.5, 0)
speedBox.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
speedBox.TextColor3 = Color3.fromRGB(255, 255, 255)
speedBox.Font = Enum.Font.Gotham
speedBox.PlaceholderText = "Tốc độ"
speedBox.Text = tostring(lastSpeed)
speedBox.TextScaled = true
speedBox.ClearTextOnFocus = false
speedBox.Parent = main

Instance.new("UICorner", speedBox).CornerRadius = UDim.new(0, 8)

local button = Instance.new("TextButton", main)
button.Size = UDim2.new(0.35, 0, 0, 25)
button.Position = UDim2.new(0.6, 0, 0.5, 0)
button.BackgroundColor3 = Color3.fromRGB(50, 255, 200)
button.TextColor3 = Color3.fromRGB(0, 0, 0)
button.Font = Enum.Font.GothamBold
button.Text = "Bật"
button.TextSize = 16
button.Parent = main

Instance.new("UICorner", button).CornerRadius = UDim.new(0, 8)

local enabled = false
local currentSpeed = lastSpeed
local targetSpeed = lastSpeed
local currentJump = lastJump
local targetJump = lastJump
local savedGravity = Workspace.Gravity
local savedCameraSubject = nil
local savedCameraType = nil
local savedCameraFov = nil

local speedConnection
local charConnection
local gravityForce
local gravityAttachment
local cameraTween

local function getCharacter()
	local char = player.Character
	if char and char.Parent then
		return char
	end
	return nil
end

local function getHumanoid(char)
	return char and char:FindFirstChildOfClass("Humanoid") or nil
end

local function getRoot(char)
	if not char then
		return nil
	end
	return char:FindFirstChild("HumanoidRootPart")
		or char:FindFirstChild("Torso")
		or char:FindFirstChild("UpperTorso")
		or char:FindFirstChild("LowerTorso")
end

local function getCamera()
	return Workspace.CurrentCamera
end

local function tweenCamera(target, time)
	local cam = getCamera()
	if not cam then
		return
	end

	if cameraTween then
		pcall(function()
			cameraTween:Cancel()
		end)
		cameraTween = nil
	end

	cameraTween = TweenService:Create(
		cam,
		TweenInfo.new(time or 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ FieldOfView = target }
	)
	cameraTween:Play()
end

local function cleanupGravityForce()
	if gravityForce then
		gravityForce:Destroy()
		gravityForce = nil
	end

	if gravityAttachment then
		gravityAttachment:Destroy()
		gravityAttachment = nil
	end
end

local function setupGravityForce(char)
	local root = getRoot(char)
	if not root then
		return
	end

	cleanupGravityForce()

	gravityAttachment = Instance.new("Attachment")
	gravityAttachment.Name = "AVADEGravityAttachment"
	gravityAttachment.Parent = root

	gravityForce = Instance.new("VectorForce")
	gravityForce.Name = "AVADEGravityForce"
	gravityForce.Attachment0 = gravityAttachment
	gravityForce.RelativeTo = Enum.ActuatorRelativeTo.World
	gravityForce.ApplyAtCenterOfMass = true
	gravityForce.Parent = root
end

local function updateGravity(char, multiplier)
	local root = getRoot(char)
	if not root then
		return
	end

	if not gravityForce or not gravityForce.Parent then
		setupGravityForce(char)
	end

	local extra = math.max(0, multiplier - 1)
	local mass = root.AssemblyMass

	if gravityForce then
		gravityForce.Force = Vector3.new(0, -mass * Workspace.Gravity * extra, 0)
	end
end

local function applyCameraState(moving, dt)
	local cam = getCamera()
	if not cam then
		return
	end

	local targetFov = moving and MOVE_FOV or IDLE_FOV
	local alpha = math.clamp(dt * 6, 0, 1)
	cam.FieldOfView = cam.FieldOfView + ((targetFov - cam.FieldOfView) * alpha)
end

local function applyCharacter(dt)
	local char = getCharacter()
	if not char then
		return
	end

	local humanoid = getHumanoid(char)
	local root = getRoot(char)
	if not humanoid or not root then
		return
	end

	local moving = humanoid.MoveDirection.Magnitude > 0.1

	if enabled then
		currentSpeed = currentSpeed + ((targetSpeed - currentSpeed) * math.clamp(dt * 5, 0, 1))
		currentJump = currentJump + ((targetJump - currentJump) * math.clamp(dt * 5, 0, 1))

		humanoid.WalkSpeed = currentSpeed
		humanoid.JumpPower = currentJump
		humanoid.UseJumpPower = true

		updateGravity(char, ENABLE_GRAVITY)
		applyCameraState(moving, dt)
	else
		currentSpeed = currentSpeed + ((DEFAULT_SPEED - currentSpeed) * math.clamp(dt * 5, 0, 1))
		currentJump = currentJump + ((DEFAULT_JUMP - currentJump) * math.clamp(dt * 5, 0, 1))

		humanoid.WalkSpeed = currentSpeed
		humanoid.JumpPower = currentJump
		humanoid.UseJumpPower = true

		updateGravity(char, 1)
	end
end

local function startLoop()
	if speedConnection then
		speedConnection:Disconnect()
		speedConnection = nil
	end

	speedConnection = RunService.RenderStepped:Connect(function(dt)
		applyCharacter(dt)
	end)
end

local function stopLoop()
	if speedConnection then
		speedConnection:Disconnect()
		speedConnection = nil
	end
end

local function enableAVADE()
	local char = getCharacter()
	if not char then
		return
	end

	local humanoid = getHumanoid(char)
	if not humanoid then
		return
	end

	local speedNum = tonumber(speedBox.Text)
	if not speedNum or speedNum <= 0 then
		speedNum = lastSpeed
		speedBox.Text = tostring(speedNum)
	end

	targetSpeed = speedNum
	targetJump = math.clamp(speedNum * 0.9, 50, 120)

	lastSpeed = speedNum
	lastJump = targetJump

	saveData({
		SpeedValue = lastSpeed,
		JumpValue = lastJump
	})

	currentSpeed = humanoid.WalkSpeed
	currentJump = humanoid.JumpPower

	local cam = getCamera()
	if cam then
		savedCameraSubject = cam.CameraSubject
		savedCameraType = cam.CameraType
		savedCameraFov = cam.FieldOfView
		cam.CameraType = Enum.CameraType.Custom
		cam.FieldOfView = IDLE_FOV
	end

	Workspace.Gravity = ENABLE_GRAVITY
	setupGravityForce(char)
	startLoop()
end

local function disableAVADE()
	stopLoop()

	local char = getCharacter()
	if char then
		local humanoid = getHumanoid(char)
		if humanoid then
			humanoid.WalkSpeed = DEFAULT_SPEED
			humanoid.JumpPower = DEFAULT_JUMP
			humanoid.UseJumpPower = true
		end
	end

	cleanupGravityForce()

	task.delay(0.15, function()
		if not enabled then
			Workspace.Gravity = savedGravity
		end
	end)

	local cam = getCamera()
	if cam then
		if cameraTween then
			pcall(function()
				cameraTween:Cancel()
			end)
			cameraTween = nil
		end

		cam.CameraType = savedCameraType or Enum.CameraType.Custom
		cam.CameraSubject = savedCameraSubject
		tweenCamera(savedCameraFov or DEFAULT_FOV, 0.45)
	end
end

local function refreshButton()
	if enabled then
		button.Text = "Tắt"
		button.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
	else
		button.Text = "Bật"
		button.BackgroundColor3 = Color3.fromRGB(50, 255, 200)
	end
end

speedBox.FocusLost:Connect(function()
	local num = tonumber(speedBox.Text)
	if num and num > 0 then
		lastSpeed = num
		lastJump = math.clamp(num * 0.9, 50, 120)

		targetSpeed = lastSpeed
		targetJump = lastJump

		saveData({
			SpeedValue = lastSpeed,
			JumpValue = lastJump
		})
	end
end)

button.MouseButton1Click:Connect(function()
	enabled = not enabled

	if enabled then
		savedGravity = Workspace.Gravity
		enableAVADE()
	else
		disableAVADE()
	end

	refreshButton()
end)

charConnection = player.CharacterAdded:Connect(function(char)
	task.wait(0.15)

	local humanoid = getHumanoid(char)
	if humanoid then
		humanoid.UseJumpPower = true
		humanoid.WalkSpeed = enabled and currentSpeed or DEFAULT_SPEED
		humanoid.JumpPower = enabled and currentJump or DEFAULT_JUMP
	end

	if enabled then
		savedGravity = Workspace.Gravity
		Workspace.Gravity = ENABLE_GRAVITY
		setupGravityForce(char)

		local cam = getCamera()
		if cam then
			cam.FieldOfView = IDLE_FOV
		end

		startLoop()
	end
end)

player.CharacterRemoving:Connect(function()
	cleanupGravityForce()
end)

if player.Character then
	local humanoid = getHumanoid(player.Character)
	if humanoid then
		humanoid.UseJumpPower = true
		humanoid.WalkSpeed = DEFAULT_SPEED
		humanoid.JumpPower = DEFAULT_JUMP
	end
end

refreshButton()

]]},
}},

