toggleButton.Font = Enum.Font.GothamBold

toggleButton.TextScaled = true

toggleButton.TextColor3 = Color3.fromRGB(0, 0, 0)

toggleButton.Text = "Tua Ngược"

Instance.new("UICorner", toggleButton).CornerRadius = UDim.new(0, 8)

local function bxor(a, b)

	if bit32 and bit32.bxor then return bit32.bxor(a, b) end

	if bit and bit.bxor then return bit.bxor(a, b) end

	local r = 0

	local bitv = 1

	while a > 0 or b > 0 do

		local aa = a % 2

		local bb = b % 2

		if aa ~= bb then r = r + bitv end

		a = math.floor(a / 2)

		b = math.floor(b / 2)

		bitv = bitv * 2

	end

	return r

end

local function safeFindByFullName(full)

	local root = game

	for segment in string.gmatch(full, "([^%.]+)") do

		if not root then return nil end

		root = root:FindFirstChild(segment)

	end

	return root

end

local function findHRP(ch)

	if not ch then return nil end

	local names = {"HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso", "Head"}

	if ch.PrimaryPart and ch.PrimaryPart:IsA("BasePart") then return ch.PrimaryPart end

	for _, n in ipairs(names) do

		local p = ch:FindFirstChild(n)

		if p and p:IsA("BasePart") then return p end

	end

	for _, d in ipairs(ch:GetDescendants()) do

		if d:IsA("BasePart") then return d end

	end

	return nil

end

local function captureSnapshot(ch)

	if not ch or not ch.Parent then return nil end

	local hrp = findHRP(ch)

	if not hrp then return nil end

	local motors = {}

	for _, m in ipairs(ch:GetDescendants()) do

		if m:IsA("Motor6D") and m.Parent then

			local p = m.Parent

			motors[#motors+1] = {partPath = p:GetFullName(), motorName = m.Name, c0 = m.C0, c1 = m.C1}

		end

	end

	local parts = {}

	for _, d in ipairs(ch:GetDescendants()) do

		if d:IsA("BasePart") and d ~= hrp then

			parts[#parts+1] = {path = d:GetFullName(), cframe = d.CFrame}

		end

	end

	return {time = tick(), hrp = hrp.CFrame, motors = motors, partCFrames = parts}

end

local recording = true

local samples = {}

local sampleInterval = 1/60

local maxSamples = 3600

local recConn = nil

local playingBack = false

local playbackConn = nil

local playbackSaved = nil

local rewindSpeedMultiplier = 1.5

local teleportThreshold = 10

local function startAutoRecord()

	if recConn then return end

	local acc = 0

	recConn = RunService.Heartbeat:Connect(function(dt)

		if playingBack then return end

		acc = acc + dt

		if acc >= sampleInterval then

			acc = acc - sampleInterval

			local ch = player.Character

			if not ch or not ch.Parent then return end

			local snap = captureSnapshot(ch)

			if snap then

				samples[#samples+1] = snap

				if #samples > maxSamples then table.remove(samples, 1) end

			end

		end

	end)

end

local function stopAutoRecord()

	if recConn then

		recConn:Disconnect()

		recConn = nil

	end

end

local function cleanupAfterPlayback()

	if not playbackSaved then return end

	for part, anchored in pairs(playbackSaved.savedAnchors or {}) do

		if part and part.Parent then

			pcall(function() part.Anchored = anchored end)

		end

	end

	if player.Character and player.Character.Parent then

		local hum = player.Character:FindFirstChildOfClass("Humanoid")

		if hum then

			pcall(function()

				hum.WalkSpeed = playbackSaved.savedWalk or 16

				hum.JumpPower = playbackSaved.savedJump or 50

			end)

		end

	end

	local cam = workspace.CurrentCamera

	if cam then

		pcall(function()

			cam.CameraSubject = playbackSaved.savedCamSubject or cam.CameraSubject

			cam.CameraType = playbackSaved.savedCamType or cam.CameraType

		end)

	end

	playbackSaved = nil

end

local function applySnapshotInstant(snap)

	if not snap then return end

	pcall(function()

		local ch = player.Character

		if ch and ch.Parent and snap.hrp then

			local hrp = findHRP(ch)

			if hrp then hrp.CFrame = snap.hrp end

		end

	end)

	for _, j in ipairs(snap.partCFrames or {}) do

		local inst = safeFindByFullName(j.path)

		if inst and inst:IsA("BasePart") and inst.Parent then

			pcall(function() inst.CFrame = j.cframe end)

		end

	end

	for _, m in ipairs(snap.motors or {}) do

		local part = safeFindByFullName(m.partPath)

		if part and part.Parent then

			local motor = part:FindFirstChild(m.motorName)

			if motor and motor:IsA("Motor6D") then

				pcall(function() motor.C0 = m.c0; motor.C1 = m.c1 end)

			end

		end

	end

end

local function startPlayback()

	if playingBack or #samples < 2 then return end

	playingBack = true

	toggleButton.Text = "Tua Ngược: Bật"

	stopAutoRecord()

	local ch = player.Character or player.CharacterAdded:Wait()

	if not ch or not ch.Parent then playingBack = false; startAutoRecord(); toggleButton.Text = "Tua"; return end

	local hrp = findHRP(ch)

	if not hrp then playingBack = false; startAutoRecord(); toggleButton.Text = "Tua"; return end

	playbackSaved = {}

	local hum = ch:FindFirstChildOfClass("Humanoid")

	if hum then

		playbackSaved.savedWalk = hum.WalkSpeed

		playbackSaved.savedJump = hum.JumpPower

		pcall(function() hum.WalkSpeed = 0; hum.JumpPower = 0 end)

	end

	playbackSaved.savedAnchors = {}

	for _, p in ipairs(ch:GetDescendants()) do

		if p:IsA("BasePart") then

			playbackSaved.savedAnchors[p] = p.Anchored

			pcall(function() p.Anchored = true end)

		end

	end

	local cam = workspace.CurrentCamera

	if cam then

		playbackSaved.savedCamSubject = cam.CameraSubject

		playbackSaved.savedCamType = cam.CameraType

		pcall(function()

			if hum then cam.CameraSubject = hum; cam.CameraType = Enum.CameraType.Custom end

		end)

	end

	local newestIndex = #samples

	local playbackTime = samples[newestIndex].time

	local idx = newestIndex

	playbackConn = RunService.RenderStepped:Connect(function(dt)

		if not playingBack then

			if playbackConn then playbackConn:Disconnect(); playbackConn = nil end

			return

		end

		playbackTime = playbackTime - dt * rewindSpeedMultiplier

		if playbackTime <= samples[1].time then

			applySnapshotInstant(samples[1])

			playingBack = false

			if playbackConn then playbackConn:Disconnect(); playbackConn = nil end

			toggleButton.Text = "Tua Ngược"

			cleanupAfterPlayback()

			startAutoRecord()

			return

		end

		while idx > 1 and playbackTime <= samples[idx-1].time do idx = idx - 1 end

		while idx < #samples and playbackTime > samples[idx].time do idx = idx + 1 end

		if idx <= 1 then applySnapshotInstant(samples[1]); return end

		local s = samples[idx]

		local g = samples[idx-1]

		local teleport = false

		if s.hrp and g.hrp then

			local ok, dist = pcall(function() return (s.hrp.p - g.hrp.p).Magnitude end)

			if not ok then

				ok, dist = pcall(function() return (s.hrp.Position - g.hrp.Position).Magnitude end)

			end

			if ok and dist and dist >= teleportThreshold then teleport = true end

		end

		if teleport then

			applySnapshotInstant(g)

			if idx > 1 then idx = idx - 1 end

			return

		end

		local span = s.time - g.time

		local alpha = span <= 0 and 0 or math.clamp((s.time - playbackTime) / span, 0, 1)

		local eased = alpha * alpha * (3 - 2 * alpha)

		pcall(function()

			local ch2 = player.Character

			if ch2 and ch2.Parent then

				local hrp2 = findHRP(ch2)

				if hrp2 and s.hrp and g.hrp then

					hrp2.CFrame = s.hrp:Lerp(g.hrp, eased)

				end

			end

		end)

		local map = {}

		for _, j in ipairs(g.partCFrames or {}) do map[j.path] = j.cframe end

		for _, j in ipairs(s.partCFrames or {}) do

			local inst = safeFindByFullName(j.path)

			if inst and inst:IsA("BasePart") and inst.Parent then

				local goal = map[j.path] or j.cframe

				pcall(function() inst.CFrame = j.cframe:Lerp(goal, eased) end)

			end

		end

		local mmap = {}

		for _, m in ipairs(g.motors or {}) do mmap[m.partPath .. "::" .. m.motorName] = m end

		for _, m in ipairs(s.motors or {}) do

			local gm = mmap[m.partPath .. "::" .. m.motorName]

			local part = safeFindByFullName(m.partPath)

			if part and part.Parent then

				local motor = part:FindFirstChild(m.motorName)

				if motor and motor:IsA("Motor6D") then

					local sC0, sC1 = m.c0, m.c1

					local gC0, gC1 = (gm and gm.c0) or sC0, (gm and gm.c1) or sC1

					pcall(function()

						motor.C0 = sC0:Lerp(gC0, eased)

						motor.C1 = sC1:Lerp(gC1, eased)

					end)

				end

			end

		end

	end)

end

local function stopPlayback()

	if not playingBack then return end

	playingBack = false

	if playbackConn then playbackConn:Disconnect(); playbackConn = nil end

	toggleButton.Text = "Tua Ngược"

	cleanupAfterPlayback()

	startAutoRecord()

end

toggleButton.MouseButton1Click:Connect(function()

	if playingBack then

		stopPlayback()

		return

	end

	if #samples < 2 then return end

	startPlayback()

end)

player.CharacterRemoving:Connect(function()

	if playingBack then stopPlayback() end

end)

player.CharacterAdded:Connect(function()

	if playingBack then stopPlayback() end

end)

startAutoRecord()

]]},

