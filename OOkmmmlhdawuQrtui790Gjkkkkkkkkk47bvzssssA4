		if not enabled or not root or not root.Parent then return end

		local dir = alignPos.Position - root.Position
		dir = Vector3.new(dir.X, 0, dir.Z)

		if dir.Magnitude > 0.001 then
			lastDir = dir.Unit
		end

		alignOri.CFrame = CFrame.lookAt(root.Position, root.Position + lastDir)

		if centerPart and centerPart.Parent then
			centerPart.CFrame = CFrame.new(center)
		end
	end)

	loopConn = task.spawn(function()
		while enabled and root and root.Parent do
			local pos = root.Position
			local target

			if outOfBounds(pos) then
				target = clamp(center)
			else
				target = clamp(randEdge(center))
			end

			alignPos.Position = target
			task.wait(moveTime)
		end

		cleanup()
	end)
end

start()

player.CharacterAdded:Connect(function()
	task.wait(0.2)
	if G.Bom2devIllusionState.active then
		cleanup()
		task.wait(0.1)
		G.Bom2devIllusionState.active = true
		G.Bom2devIllusionState.cleanup = cleanup
		start()
	end
end)

