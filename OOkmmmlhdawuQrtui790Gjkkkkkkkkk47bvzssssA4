{Text = {vn = "Ring", en = "Ring"}, Script = [[

local Players = game:GetService("Players")

local RunService = game:GetService("RunService")

local UserInputService = game:GetService("UserInputService")

local Workspace = game:GetService("Workspace")

local GuiService = game:GetService("GuiService")

local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer

local playerGui = LocalPlayer:WaitForChild("PlayerGui")

local SPEED = 1000

local spinSpeed = 10

if playerGui:FindFirstChild("KitaimoraRingGuiShape") then

	playerGui:FindFirstChild("KitaimoraRingGuiShape"):Destroy()end

local gui = Instance.new("ScreenGui")

gui.Name = "KitaimoraRingGuiShape"

gui.ResetOnSpawn = false

gui.IgnoreGuiInset = true

gui.Parent = playerGui

local main = Instance.new("Frame")

main.Size = UDim2.new(0,160,0,60)

main.Position = UDim2.new(0.05,0,0.8,0)

main.BackgroundColor3 = Color3.fromRGB(14,14,22)

main.BackgroundTransparency = 0.06

main.Parent = gui

Instance.new("UICorner", main).CornerRadius = UDim.new(0,12)

local stroke = Instance.new("UIStroke", main)

stroke.Thickness = 2

stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

task.spawn(function()

	local hue = 0

	while task.wait(0.05) and gui.Parent do

		hue = (hue + 0.01) % 1

		stroke.Color = Color3.fromHSV(hue,1,1)

	end

end)

main.Active = true

local dragging, dragInput, dragStart, startPos

local function updateDrag(input)

	if not dragging then return end

	local delta = input.Position - dragStart

	main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)

end

main.InputBegan:Connect(function(input)

	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then

		dragging = true

		dragStart = input.Position

		startPos = main.Position

		input.Changed:Connect(function()

			if input.UserInputState == Enum.UserInputState.End then

				dragging = false

			end

		end)

	end

end)

main.InputChanged:Connect(function(input)

	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then

		dragInput = input

	end

end)

UserInputService.InputChanged:Connect(function(input)

	if input == dragInput then updateDrag(input) end

end)

local title = Instance.new("TextLabel", main)

title.Size = UDim2.new(1,0,0,20)

title.BackgroundTransparency = 1

title.Font = Enum.Font.GothamBold

title.TextSize = 14

title.Text = "Ring"

title.TextColor3 = Color3.fromRGB(210,230,255)

title.TextXAlignment = Enum.TextXAlignment.Center

local radiusBox = Instance.new("TextBox", main)

radiusBox.Size = UDim2.new(0.55,0,0,25)

radiusBox.Position = UDim2.new(0.05,0,0.5,0)

radiusBox.BackgroundColor3 = Color3.fromRGB(24,24,32)

radiusBox.PlaceholderText = "Bán Kính"

radiusBox.ClearTextOnFocus = false

radiusBox.Font = Enum.Font.Gotham

radiusBox.TextScaled = true

radiusBox.TextColor3 = Color3.fromRGB(240,240,240)

radiusBox.Text = "50"

Instance.new("UICorner", radiusBox).CornerRadius = UDim.new(0,8)

local toggleBtn = Instance.new("TextButton", main)

toggleBtn.Size = UDim2.new(0.35,0,0,25)

toggleBtn.Position = UDim2.new(0.62,0,0.5,0)

toggleBtn.BackgroundColor3 = Color3.fromRGB(70,45,140)

toggleBtn.Text = "Ring"

toggleBtn.Font = Enum.Font.GothamBold

toggleBtn.TextSize = 14

toggleBtn.TextColor3 = Color3.fromRGB(230,230,255)

Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0,8)

local infoLabel = Instance.new("TextLabel", main)

infoLabel.Size = UDim2.new(1, -16, 0, 18)

infoLabel.Position = UDim2.new(0, 8, 0.78, 0)

infoLabel.BackgroundTransparency = 1

infoLabel.Font = Enum.Font.Gotham

infoLabel.TextSize = 12

infoLabel.Text = " "

infoLabel.TextColor3 = Color3.fromRGB(190,190,255)

infoLabel.TextXAlignment = Enum.TextXAlignment.Left

if not getgenv().KitaRingState then

	getgenv().KitaRingState = {

		enabled = false,

		radii = {50},

		shape = "circle",

		speed = 18,

		angle = 0,

		modified = {},

		targets = {},

		visuals = {},

		centerPart = nil,

		conn = nil,

		launched = false,

		tweens = {},

		slots = 150,

		following = true,

		partPool = {},

		poolIndex = 1,

		attachBatch = 60,

		attachInterval = 0.001,

		_lastAttach = 0,

		poolLimit = math.huge,

		_dynamicAttachCount = 0,

		_descConn = nil,

		_propConns = {},

		_slotsPerRing = 0,

		_totalSlots = 0,

	}

end

local state = getgenv().KitaRingState

local math_cos, math_sin = math.cos, math.sin

local function ensureCenter()

	if state.centerPart and state.centerPart.Parent then return end

	local cp = Instance.new("Part")

	cp.Size = Vector3.new(1,1,1)

	cp.Transparency = 1

	cp.Anchored = true

	cp.CanCollide = false

	cp.Name = "KitaRing_Center"

	cp.Parent = Workspace

	state.centerPart = cp

end

local function clearTargets()

	for _,t in ipairs(state.targets) do		if t and t.Parent then pcall(function() t:Destroy() end) end

	end

	state.targets = {}

	state._totalSlots = 0

	state._slotsPerRing = 0

end

local function clearModified()

	for part,rec in pairs(state.modified) do

		if rec then

			if rec.targ and rec.targ.Parent then pcall(function() rec.targ:Destroy() end) end

			if part and part.Parent then

				pcall(function()

					local ap = part:FindFirstChild("KitaAlignPos"); if ap then ap:Destroy() end

					local ao = part:FindFirstChild("KitaAlignOri"); if ao then ao:Destroy() end

					local att = part:FindFirstChild("KitaAttachment"); if att then att:Destroy() end

					if rec.anchoredBefore ~= nil then part.Anchored = rec.anchoredBefore end

					if rec.canCollideBefore ~= nil then part.CanCollide = rec.canCollideBefore end

				end)

			end

		end

	end

	state.modified = {}

end

local function clearVisuals()

	for _,v in ipairs(state.visuals) do

		if v and v.Parent then pcall(function() v:Destroy() end) end

	end

	state.visuals = {}

end

local function makeTargetAt(cframe)

	local p = Instance.new("Part")

	p.Size = Vector3.new(0.5,0.5,0.5)

	p.Transparency = 1

	p.Anchored = true

	p.CanCollide = false

	p.Name = "KitaRingTarget"

	p.CFrame = cframe

	p.Parent = Workspace

	table.insert(state.targets, p)

	return p

end

local function ensureVisualCount(n)

	if n <= 0 then return end

	while #state.visuals < n do

		local p = Instance.new("Part")

		p.Size = Vector3.new(0.6,0.6,0.6)

		p.Anchored = true

		p.CanCollide = false

		p.Transparency = 0.45

		p.Shape = Enum.PartType.Ball

		p.Material = Enum.Material.Neon

		p.Name = "KitaRingVisual"

		p.Parent = Workspace

		table.insert(state.visuals, p)

	end

	while #state.visuals > n do

		local v = table.remove(state.visuals)

		if v and v.Parent then pcall(function() v:Destroy() end) end

	end

end

local function makeAlignFor(part, target)

	if not part or not part:IsA("BasePart") or not target then return end

	if state.modified[part] then return end

	local rec = {}

	rec.targ = target

	rec.anchoredBefore = part.Anchored

	rec.canCollideBefore = part.CanCollide

	part.Anchored = false

	part.CanCollide = false

	pcall(function() part:SetNetworkOwner(nil) end)

	local ap = part:FindFirstChild("KitaAlignPos")

	if not ap then

		ap = Instance.new("AlignPosition")

		ap.Name = "KitaAlignPos"

		ap.MaxForce = math.huge

		ap.MaxVelocity = math.huge

		ap.Responsiveness = 100

		ap.ApplyAtCenterOfMass = true

		ap.Parent = part

	else

		ap.MaxForce = math.huge

		ap.MaxVelocity = math.huge

		ap.Responsiveness = 100

		ap.ApplyAtCenterOfMass = true

	end

	local ao = part:FindFirstChild("KitaAlignOri")

	if not ao then

		ao = Instance.new("AlignOrientation")

		ao.Name = "KitaAlignOri"

		ao.MaxTorque = math.huge

		ao.MaxAngularVelocity = 200

		ao.Responsiveness = 100

		ao.Parent = part

	else

		ao.MaxTorque = math.huge

		ao.MaxAngularVelocity = 200

		ao.Responsiveness = 100

	end

	local a0 = part:FindFirstChild("KitaAttachment")

	if not a0 then

		a0 = Instance.new("Attachment")

		a0.Name = "KitaAttachment"

		a0.Parent = part

	end

	local a1 = target:FindFirstChildOfClass("Attachment")

	if not a1 then

		a1 = Instance.new("Attachment")

		a1.Parent = target

	end

	ap.Attachment0 = a0

	ap.Attachment1 = a1

	ao.Attachment0 = a0

	ao.Attachment1 = a1

	state.modified[part] = rec

end

local function collectAllUnanchoredPartsOnce()

	local list = {}

	for _,obj in ipairs(Workspace:GetDescendants()) do

		if #list >= state.poolLimit then break end

		if obj:IsA("BasePart")

		and not obj:IsDescendantOf(LocalPlayer.Character)

		and obj.Name ~= "KitaRingTarget"

		and obj.Name ~= "KitaRing_Center"

		and obj.Name ~= "KitaRingVisual"

		and not obj.Anchored then

			table.insert(list, obj)

		end

	end

	return list

end

local function shapePoint(slotIdx, slotsPerRing, radius, shape)

	local s = (slotIdx-1)/slotsPerRing

	if shape == "circle" then

		local ang = s * 2 * math.pi

		return Vector3.new(math.cos(ang)*radius, 0, math.sin(ang)*radius)

	end

	if shape == "square" or shape == "triangle" then

		local n = (shape == "square") and 4 or 3

		local verts = {}

		for i=0,(n-1) do

