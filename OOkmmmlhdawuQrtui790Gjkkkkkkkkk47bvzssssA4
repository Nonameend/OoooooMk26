local function Fling(Target)
	local Character = LocalPlayer.Character
	local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
	local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")

	local TCharacter = Target.Character

	if not Character or not Humanoid or not RootPart or not TCharacter then
		return
	end

	local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
	local TRootPart = TCharacter:FindFirstChild("HumanoidRootPart")

	if not THumanoid or not TRootPart then
		return
	end

	if THumanoid.Health <= -1 then
		return
	end

	local Old = RootPart.CFrame

	local oldFPDH = workspace.FallenPartsDestroyHeight
	workspace.FallenPartsDestroyHeight = 0/0

	local BV = Instance.new("BodyVelocity")
	BV.Parent = RootPart
	BV.Velocity = Vector3.zero
	BV.MaxForce = Vector3.new(math.huge,math.huge,math.huge)

	local BG = Instance.new("BodyAngularVelocity")
	BG.Parent = RootPart
	BG.MaxTorque = Vector3.new(math.huge,math.huge,math.huge)
	BG.AngularVelocity = Vector3.new(
		9e8,
		9e8,
		9e8
	)
	BG.P = math.huge

	Humanoid:SetStateEnabled(
		Enum.HumanoidStateType.Seated,
		false
	)

	RootPart.CanCollide = false

	local start = tick()

	while tick() - start < 0.05 and Flinging do
	RootPart.CFrame =
		TRootPart.CFrame *
		CFrame.new(
			math.random(-2,2),
			math.random(-2,2),
			math.random(-2,2)
		) *
		CFrame.Angles(
			math.rad(math.random(-9999,9999)),
			math.rad(math.random(-9999,9999)),
			math.rad(math.random(-9999,9999))
		)

	RootPart.AssemblyLinearVelocity =
		Vector3.new(
			9e8,
			9e8,
			9e8
		)

	RootPart.AssemblyAngularVelocity =
		Vector3.new(
			9e8,
			9e8,
			9e8
		)

	RunService.Heartbeat:Wait()
end

	BV:Destroy()
	BG:Destroy()

	RootPart.AssemblyLinearVelocity = Vector3.zero
	RootPart.AssemblyAngularVelocity = Vector3.zero

	RootPart.CFrame = Old
	RootPart.CanCollide = true

	Humanoid:SetStateEnabled(
		Enum.HumanoidStateType.Seated,
		true
	)

	workspace.FallenPartsDestroyHeight = oldFPDH
end

