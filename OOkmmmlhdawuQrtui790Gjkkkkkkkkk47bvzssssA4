local excluded = {HumanoidRootPart=true}

local function isAccessoryPart(part)

	local p = part

	while p and p.Parent do

		p = p.Parent

		if p and p:IsA("Accessory") then return true end

	end

	return false

end

local function setTransparencyForCharacter(ch, transparency)

	if not ch then return end

	for _,obj in ipairs(ch:GetDescendants()) do

		if obj:IsA("BasePart") then

			if excluded[obj.Name] then

			else

				local keep = false

				if namedParts[obj.Name] then keep = true end

				if isAccessoryPart(obj) then keep = true end

				if keep then

					pcall(function() obj.Transparency = transparency end)

				end

			end

		elseif obj:IsA("Decal") then

			local p = obj.Parent

			if p and p:IsA("BasePart") and not excluded[p.Name] then

				local keep = false

				if namedParts[p.Name] then keep = true end

				if isAccessoryPart(p) then keep = true end

				if keep then pcall(function() obj.Transparency = transparency end) end

			end

		end

	end

end

local function restoreCharacterTransparency(ch)

	if not ch then return end

	for _,obj in ipairs(ch:GetDescendants()) do

		if obj:IsA("BasePart") then

			if not excluded[obj.Name] then

				if namedParts[obj.Name] or isAccessoryPart(obj) then

					pcall(function() obj.Transparency = 0 end)

				end

			end

		elseif obj:IsA("Decal") then

			local p = obj.Parent

			if p and p:IsA("BasePart") and not excluded[p.Name] then

				if namedParts[p.Name] or isAccessoryPart(p) then

					pcall(function() obj.Transparency = 0 end)

				end

			end

		end

	end

end

local function neutralizeBodyMovers(ch)

	if not ch then return end

	for _,obj in ipairs(ch:GetDescendants()) do

		if obj:IsA("BodyVelocity") or obj:IsA("BodyGyro") or obj:IsA("BodyPosition") or obj:IsA("BodyForce") or obj:IsA("BodyThrust") or obj:IsA("AlignPosition") or obj:IsA("AlignOrientation") or obj:IsA("VectorForce") or obj:IsA("LinearVelocity") then

			pcall(function() obj:Destroy() end)

		end

	end

end

local function onDescendantAdded(obj)

	if toggleButton:GetAttribute("InvisOn") ~= true then return end

	if not obj then return end

	local ch = player.Character

	if not ch then return end

	if obj:IsA("BasePart") then

		if not excluded[obj.Name] then

			local keep = false

			if namedParts[obj.Name] then keep = true end

			if isAccessoryPart(obj) then keep = true end

			if keep then pcall(function() obj.Transparency = 0.5 end) end

		end

	elseif obj:IsA("Decal") then

		local p = obj.Parent

		if p and p:IsA("BasePart") and not excluded[p.Name] then

			local keep = false

			if namedParts[p.Name] then keep = true end

			if isAccessoryPart(p) then keep = true end

			if keep then pcall(function() obj.Transparency = 0.5 end) end

		end

	end

	if obj:IsA("Instance") then

		pcall(function() neutralizeBodyMovers(ch) end)

	end

end

local function createInvisChairAt(cf)

	local seat = Instance.new("Seat")

	seat.Name = "invischair"

	seat.Anchored = false

	seat.CanCollide = false

	seat.Transparency = 1

	seat.CFrame = cf

	seat.Parent = Workspace

	return seat

end

local function startEnforce(ch)

	if invisConn then return end

	local character = ch or player.Character

	if not character then return end

	setTransparencyForCharacter(character, 0.5)

	if charDescConn then pcall(function() charDescConn:Disconnect() end); charDescConn = nil end

	charDescConn = character.DescendantAdded:Connect(onDescendantAdded)

	invisConn = RunService.RenderStepped:Connect(function()

		local c = player.Character

		if not c then return end

		setTransparencyForCharacter(c, 0.5)

		neutralizeBodyMovers(c)

	end)

	neutralizeBodyMovers(character)

end

local function stopEnforce()

	if invisConn then pcall(function() invisConn:Disconnect() end); invisConn = nil end

	if charDescConn then pcall(function() charDescConn:Disconnect() end); charDescConn = nil end

end

local function toggleInvisibility()

	local on = toggleButton:GetAttribute("InvisOn")

	on = not on

	toggleButton:SetAttribute("InvisOn", on)

	pcall(function() sound:Play() end)

	if on then

		local ch = player.Character

		if ch and ch:FindFirstChild("HumanoidRootPart") then

			local hrp = ch:FindFirstChild("HumanoidRootPart")

			local savedpos = nil

			pcall(function() savedpos = hrp.CFrame end)

			task.wait()

			pcall(function() ch:MoveTo(Vector3.new(0, 999999999999, 0)) end)

			task.wait(0.13)

			local cf = savedpos or (hrp and hrp.CFrame) or CFrame.new(0,0,0)

			local seat = createInvisChairAt(cf)

			local torso = ch:FindFirstChild("Torso") or ch:FindFirstChild("UpperTorso") or ch:FindFirstChild("LowerTorso") or hrp

			local weld = Instance.new("Weld")

			weld.Part0 = seat

			weld.Part1 = torso

			weld.Parent = seat

			task.wait()

			setTransparencyForCharacter(ch, 0.5)

		end

		startEnforce()

		toggleButton.Text = "Tàng Hình: Tắt"

		toggleButton.BackgroundColor3 = Color3.fromRGB(255,100,100)

	else

		local invisChair = Workspace:FindFirstChild("invischair")

		if invisChair then

			pcall(function() invisChair:Destroy() end)

		end

		stopEnforce()

		local ch = player.Character

		if ch then

			restoreCharacterTransparency(ch)

		end

		toggleButton.Text = "Tàng Hình: Bật"

		toggleButton.BackgroundColor3 = Color3.fromRGB(60,200,170)

	end

end

toggleButton.MouseButton1Click:Connect(toggleInvisibility)

player.CharacterAdded:Connect(function()

	task.wait(0.13)

	local ch = player.Character

	if not ch then return end

	if toggleButton:GetAttribute("InvisOn") then

		setTransparencyForCharacter(ch, 0.5)

		startEnforce(ch)

	else

		stopEnforce()

		restoreCharacterTransparency(ch)

	end

end)

