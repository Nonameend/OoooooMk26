	toggleButton:SetAttribute("FlingOn", FlingActive)

	if FlingActive then
		toggleButton.Text = "KillAura: Tắt"

		local char = Player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			getgenv().OldPos = char.HumanoidRootPart.CFrame
		end

		task.spawn(function()
	local idx = 1

	while FlingActive and gui.Parent do
		local playersList = Players:GetPlayers()

		if #playersList > 1 then
			idx = (idx % #playersList) + 1
			local target = playersList[idx]

			if target ~= Player then
				local char = target.Character
				local hum = char and char:FindFirstChildOfClass("Humanoid")
				local root = char and char:FindFirstChild("HumanoidRootPart")

				if hum and hum.Health > 0 and root then
